# Variáveis de ambiente do app admin (copie para .env.local e preencha).
# NUNCA comite o .env.local (já está no .gitignore).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: server-only. Usada pela borda do widget (bypassa RLS, escopo forçado no código)
# e pela criação de administradores no painel (a Admin API do Auth exige service role).
SUPABASE_SERVICE_ROLE_KEY=

# --- Criptografia de segredos (AES-256-GCM) ---
# base64 de 32 bytes. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# --- Observabilidade (opcional) ---
# Defina para encaminhar erros ao Sentry (drop-in em lib/observability.ts).
SENTRY_DSN=
